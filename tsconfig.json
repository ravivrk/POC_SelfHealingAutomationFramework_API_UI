
{
  "compilerOptions": {
    "target": "ES2020",
     "module": "Node16",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,

    "resolveJsonModule": true,
    "moduleResolution": "node16",   

    "types": ["node", "mocha"]
  },
  "include": ["src", "config", "scripts"],
  "exclude": ["node_modules", "dist"]
}
